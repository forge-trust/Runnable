@model ForgeTrust.Runnable.Web.RazorDocs.Models.RazorDocsVersionArchiveViewModel
@{
    ViewData["Title"] = "Documentation versions";
}

<div class="grid gap-8">
    <header class="grid gap-3">
        <p class="m-0 text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-cyan-300">Docs Archive</p>
        <h1 class="m-0 text-[clamp(2rem,4vw,3rem)] font-bold leading-[1.02] text-slate-50">@Model.Heading</h1>
        <p class="m-0 max-w-[52rem] text-base leading-[1.6] text-slate-400">@Model.Description</p>
        @if (!string.IsNullOrWhiteSpace(Model.AvailabilityMessage))
        {
            <div class="rounded-[1rem] border border-amber-400/30 bg-amber-500/10 px-4 py-3 text-sm leading-[1.55] text-amber-100">
                @Model.AvailabilityMessage
            </div>
        }
        <div class="flex flex-wrap gap-3">
            <a href="@Url.PathBaseAware(Model.PreviewHref)"
               data-turbo-frame="_top"
               class="inline-flex items-center gap-2 rounded-full border border-cyan-400/45 bg-cyan-500/10 px-4 py-2 text-sm font-semibold text-cyan-100 no-underline transition-colors hover:border-cyan-300 hover:bg-cyan-500/15">
                Open preview docs
            </a>
            <a href="@Url.PathBaseAware(Model.VersionsHref)"
               class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/70 px-4 py-2 text-sm font-semibold text-slate-100 no-underline transition-colors hover:border-slate-500 hover:text-white">
                Refresh archive
            </a>
        </div>
    </header>

    @if (Model.Versions.Count == 0)
    {
        <section class="rounded-[1.1rem] border border-slate-800 bg-slate-950/55 p-6 text-sm leading-[1.65] text-slate-300">
            No published versions are currently listed in the configured archive catalog.
        </section>
    }
    else
    {
        <section class="grid gap-4">
            @foreach (var version in Model.Versions)
            {
                <article class="grid gap-3 rounded-[1.1rem] border border-slate-800 bg-slate-950/55 p-5">
                    <div class="flex flex-wrap items-center gap-2">
                        <h2 class="m-0 text-xl font-semibold text-slate-50">@version.Label</h2>
                        <span class="rounded-full border border-slate-700 bg-slate-900 px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-slate-300">@version.SupportStateLabel</span>
                        @if (version.IsRecommended)
                        {
                            <span class="rounded-full border border-cyan-400/40 bg-cyan-500/10 px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-cyan-200">Recommended</span>
                        }
                        @if (!string.IsNullOrWhiteSpace(version.AdvisoryLabel))
                        {
                            <span class="rounded-full border border-rose-400/35 bg-rose-500/10 px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.16em] text-rose-200">@version.AdvisoryLabel</span>
                        }
                    </div>

                    <p class="m-0 text-sm text-slate-400">
                        @if (!string.IsNullOrWhiteSpace(version.Summary))
                        {
                            @version.Summary
                        }
                        else
                        {
                            <text>Exact version <code>@version.Version</code>.</text>
                        }
                    </p>

                    @if (version.IsAvailable && !string.IsNullOrWhiteSpace(version.Href))
                    {
                        <div>
                            <a href="@Url.PathBaseAware(version.Href)"
                               data-turbo-frame="_top"
                               class="inline-flex items-center gap-2 rounded-full border border-cyan-400/45 bg-cyan-500/10 px-4 py-2 text-sm font-semibold text-cyan-100 no-underline transition-colors hover:border-cyan-300 hover:bg-cyan-500/15">
                                Open @version.Version
                            </a>
                        </div>
                    }
                    else
                    {
                        <p class="m-0 text-sm leading-[1.55] text-amber-200">
                            @version.AvailabilityMessage
                        </p>
                    }
                </article>
            }
        </section>
    }
</div>
