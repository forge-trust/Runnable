<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup>
    <TailwindVersion>4.1.18</TailwindVersion>
    <TailwindBaseUrl>https://github.com/tailwindlabs/tailwindcss/releases/download/v$(TailwindVersion)</TailwindBaseUrl>
    <TailwindBinaryName Condition="$([MSBuild]::IsOSPlatform('Windows'))">tailwindcss-windows-x64.exe</TailwindBinaryName>
    <TailwindBinaryName Condition="$([MSBuild]::IsOSPlatform('OSX')) and '$([System.Runtime.InteropServices.RuntimeInformation]::ProcessArchitecture)' == 'Arm64'">tailwindcss-macos-arm64</TailwindBinaryName>
    <TailwindBinaryName Condition="$([MSBuild]::IsOSPlatform('OSX')) and '$([System.Runtime.InteropServices.RuntimeInformation]::ProcessArchitecture)' == 'X64'">tailwindcss-macos-x64</TailwindBinaryName>
    <TailwindBinaryName Condition="$([MSBuild]::IsOSPlatform('Linux')) and '$([System.Runtime.InteropServices.RuntimeInformation]::ProcessArchitecture)' == 'X64'">tailwindcss-linux-x64</TailwindBinaryName>
    <TailwindBinaryName Condition="$([MSBuild]::IsOSPlatform('Linux')) and '$([System.Runtime.InteropServices.RuntimeInformation]::ProcessArchitecture)' == 'Arm64'">tailwindcss-linux-arm64</TailwindBinaryName>
    <TailwindDownloadUrl>$(TailwindBaseUrl)/$(TailwindBinaryName)</TailwindDownloadUrl>
    <TailwindLocalPath>$(MSBuildProjectDirectory)\tailwindcss</TailwindLocalPath>
    <TailwindLocalPath Condition="$([MSBuild]::IsOSPlatform('Windows'))">$(TailwindLocalPath).exe</TailwindLocalPath>
  </PropertyGroup>

  <PropertyGroup>
    <TailwindSumsUrl>$(TailwindBaseUrl)/sha256sums.txt</TailwindSumsUrl>
  </PropertyGroup>

  <Target Name="ResolveTailwindBinary" BeforeTargets="PrepareForBuild;Pack">
    <PropertyGroup>
      <ChecksumFile>$(IntermediateOutputPath)sha256sums.txt</ChecksumFile>
      <DownloadTemp>$(IntermediateOutputPath)tailwindcss_download</DownloadTemp>
    </PropertyGroup>

    <DownloadFile SourceUrl="$(TailwindSumsUrl)" DestinationFolder="$(IntermediateOutputPath)" DestinationFileName="sha256sums.txt" Condition="!Exists('$(ChecksumFile)')" />
    
    <ReadLinesFromFile File="$(ChecksumFile)">
      <Output TaskParameter="Lines" ItemName="ChecksumLines" />
    </ReadLinesFromFile>

    <PropertyGroup>
      <ExpectedHashLine>%(ChecksumLines.Identity)</ExpectedHashLine>
      <ExpectedHashLine Condition="$([System.String]::new('%(ChecksumLines.Identity)').Contains('$(TailwindBinaryName)'))">%(ChecksumLines.Identity)</ExpectedHashLine>
      <ExpectedHash>$([System.String]::new('$(ExpectedHashLine)').Split(' ')[0].Trim())</ExpectedHash>
    </PropertyGroup>

    <DownloadFile SourceUrl="$(TailwindDownloadUrl)" DestinationFolder="$(IntermediateOutputPath)" DestinationFileName="tailwindcss_download" Condition="!Exists('$(TailwindLocalPath)')">
      <Output TaskParameter="DownloadedFile" ItemName="DownloadedTailwindFile" />
    </DownloadFile>

    <ItemGroup Condition="Exists('$(TailwindLocalPath)')">
      <DownloadedTailwindFile Include="$(TailwindLocalPath)" />
    </ItemGroup>

    <GetFileHash Files="@(DownloadedTailwindFile)" Algorithm="SHA256">
      <Output TaskParameter="Items" ItemName="ComputedHashes" />
    </GetFileHash>

    <PropertyGroup>
      <ComputedHash>%(ComputedHashes.FileHash)</ComputedHash>
    </PropertyGroup>

    <Error Text="Tailwind CLI checksum mismatch! Expected: $(ExpectedHash), Computed: $(ComputedHash)" Condition="'$(ExpectedHash)' != '' and '$(ComputedHash)' != '' and '$(ExpectedHash.ToLower())' != '$(ComputedHash.ToLower())'" />
    <Message Importance="high" Text="Tailwind CLI checksum verified: $(ComputedHash)" Condition="'$(ExpectedHash.ToLower())' == '$(ComputedHash.ToLower())'" />

    <Move SourceFiles="@(DownloadedTailwindFile)" DestinationFiles="$(TailwindLocalPath)" Condition="!Exists('$(TailwindLocalPath)')" />
    <Exec Command="chmod +x &quot;$(TailwindLocalPath)&quot;" Condition="!$([MSBuild]::IsOSPlatform('Windows'))" />

    <ItemGroup>
      <None Include="$(TailwindLocalPath)" CopyToOutputDirectory="PreserveNewest" Pack="true" PackagePath="runtimes/$(RuntimeIdentifier)/native" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <ProjectReference Include="../../ForgeTrust.Runnable.Core/ForgeTrust.Runnable.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- This allows the targets file to be bundled in the NuGet package -->
  <ItemGroup>
    <None Include="build\ForgeTrust.Runnable.Web.Tailwind.targets" Pack="true" PackagePath="build" />
  </ItemGroup>
</Project>
