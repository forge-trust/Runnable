@model ForgeTrust.Runnable.Web.RazorDocs.Models.DocSidebarViewModel
@{
    const string PrimaryNavLinkClass = "block rounded-md px-2 py-1.5 text-sm font-medium text-slate-400 transition-all hover:bg-slate-900 hover:text-cyan-400";
}

@foreach (var group in Model.Groups)
{
    <div class="py-2">
        <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest px-2 mb-2">@group.Title</h3>

        @if (group.RootLink is not null)
        {
            <a href="@group.RootLink.Href"
               data-turbo-frame="doc-content"
               data-turbo-action="advance"
               class="@PrimaryNavLinkClass">
                @group.RootLink.Title
            </a>
        }

        <div class="@(group.RootLink is not null ? "space-y-2" : string.Empty)">
            @foreach (var sidebarSection in group.Sections)
            {
                if (!string.IsNullOrWhiteSpace(sidebarSection.Title))
                {
                    <div class="mt-2">
                        <div class="px-2 pb-1 text-[10px] font-semibold uppercase tracking-widest text-slate-600">@sidebarSection.Title</div>
                        @await Html.PartialAsync("~/Views/Shared/Components/Sidebar/_SidebarItems.cshtml", sidebarSection.Items)
                    </div>
                }
                else
                {
                    @await Html.PartialAsync("~/Views/Shared/Components/Sidebar/_SidebarItems.cshtml", sidebarSection.Items)
                }
            }
        </div>
    </div>
}
