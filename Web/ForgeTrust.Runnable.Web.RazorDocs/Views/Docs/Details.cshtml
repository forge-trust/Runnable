@model ForgeTrust.Runnable.Web.RazorDocs.Models.DocDetailsViewModel
@{
    var document = Model.Document;
    var metadata = document.Metadata;
    var resolvedTitle = string.IsNullOrWhiteSpace(metadata?.Title)
        ? document.Title
        : metadata!.Title!.Trim();
    var summary = metadata?.Summary;
    var hasSummary = !string.IsNullOrWhiteSpace(summary);
    var summaryIsDerived = metadata?.SummaryIsDerived == true;
    var showSummary = hasSummary && !summaryIsDerived;
    ViewData["Title"] = resolvedTitle;
    var isCSharpApiDoc = document.Path.EndsWith(".cs", StringComparison.OrdinalIgnoreCase);
    var pageTypeBadge = DocMetadataPresentation.ResolvePageTypeBadge(metadata?.PageType);
    var component = metadata?.ComponentIsDerived == true || string.IsNullOrWhiteSpace(metadata?.Component)
        ? null
        : metadata!.Component!.Trim();
    var audience = metadata?.AudienceIsDerived == true || string.IsNullOrWhiteSpace(metadata?.Audience)
        ? null
        : metadata!.Audience!.Trim();
    var normalizedPath = document.Path.Trim().Trim('/');
    var isNamespacePath = normalizedPath.Equals("Namespaces", StringComparison.OrdinalIgnoreCase)
                          || normalizedPath.StartsWith("Namespaces/", StringComparison.OrdinalIgnoreCase);
    var metadataBreadcrumbs = metadata?.Breadcrumbs?
        .Where(label => !string.IsNullOrWhiteSpace(label))
        .Select(label => label.Trim())
        .ToList();
    var parsedBreadcrumbs = new List<(string Label, string? Href)>();

    if (isNamespacePath)
    {
        parsedBreadcrumbs.Add(("Namespaces", "/docs/Namespaces.html"));

        if (normalizedPath.StartsWith("Namespaces/", StringComparison.OrdinalIgnoreCase))
        {
            var fullNamespace = normalizedPath["Namespaces/".Length..];
            var parts = fullNamespace.Split('.', StringSplitOptions.RemoveEmptyEntries);
            for (var i = 0; i < parts.Length; i++)
            {
                var prefix = string.Join(".", parts.Take(i + 1));
                var isLast = i == parts.Length - 1;
                parsedBreadcrumbs.Add((parts[i], isLast ? null : $"/docs/Namespaces/{prefix}.html"));
            }
        }
    }
    else
    {
        var segments = normalizedPath.Split('/', StringSplitOptions.RemoveEmptyEntries);
        var current = string.Empty;
        for (var i = 0; i < segments.Length; i++)
        {
            var segment = segments[i];
            current = string.IsNullOrEmpty(current) ? segment : $"{current}/{segment}";
            var isLast = i == segments.Length - 1;
            var href = isLast ? null : $"/docs/{current}.html";
            parsedBreadcrumbs.Add((segment, href));
        }
    }

    var breadcrumbs = new List<(string Label, string? Href)>();
    var metadataBreadcrumbCount = metadataBreadcrumbs?.Count ?? 0;
    var hasMetadataBreadcrumbs = metadataBreadcrumbCount > 0;
    var metadataBreadcrumbsMatchPathTargets = metadata?.BreadcrumbsMatchPathTargets == true;
    var metadataBreadcrumbCountMatchesPath = metadataBreadcrumbCount == parsedBreadcrumbs.Count;
    var canUseMetadataBreadcrumbs = hasMetadataBreadcrumbs
                                    && metadataBreadcrumbsMatchPathTargets
                                    && metadataBreadcrumbCountMatchesPath;

    if (canUseMetadataBreadcrumbs)
    {
        for (var i = 0; i < metadataBreadcrumbs!.Count; i++)
        {
            breadcrumbs.Add((metadataBreadcrumbs[i], parsedBreadcrumbs[i].Href));
        }
    }
    else
    {
        breadcrumbs.AddRange(parsedBreadcrumbs);
    }
}

<header class="@(isCSharpApiDoc ? "mb-5" : "mb-8")">
    <nav aria-label="Breadcrumb" class="flex flex-wrap items-center gap-1 text-xs font-mono text-slate-500 mb-3">
        @for (var i = 0; i < breadcrumbs.Count; i++)
        {
            var crumb = breadcrumbs[i];
            var isLast = i == breadcrumbs.Count - 1;

            if (isLast || string.IsNullOrWhiteSpace(crumb.Href))
            {
                <span class="inline-flex max-w-full overflow-x-auto px-2 py-0.5 rounded bg-slate-800 border border-slate-700 whitespace-nowrap">@crumb.Label</span>
            }
            else
            {
                <a href="@crumb.Href"
                   data-turbo-frame="doc-content"
                   data-turbo-action="advance"
                   class="px-1 text-slate-400 hover:text-cyan-400 transition-colors">@crumb.Label</a>
            }

            if (!isLast)
            {
                <span class="text-slate-600">/</span>
            }
        }
    </nav>
    @if (pageTypeBadge is not null || component is not null || audience is not null)
    {
        <div class="docs-page-meta">
            @if (pageTypeBadge is not null)
            {
                <span class="docs-page-badge docs-page-badge--@pageTypeBadge.Variant">@pageTypeBadge.Label</span>
            }
            @if (component is not null)
            {
                <span class="docs-metadata-chip">Component: @component</span>
            }
            @if (audience is not null)
            {
                <span class="docs-metadata-chip">Audience: @audience</span>
            }
        </div>
    }
    @if (!isCSharpApiDoc)
    {
        <h1 class="text-3xl font-bold text-white tracking-tight">@resolvedTitle</h1>
        @if (showSummary)
        {
            <p class="mt-3 max-w-3xl text-base text-slate-400">@summary</p>
        }
    }
</header>

@if (Model.HasOutline)
{
    <section id="docs-page-outline" class="mb-8 rounded-2xl border border-slate-800 bg-slate-900/60 px-4 py-4">
        <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">On this page</div>
        <nav aria-label="On this page" class="mt-3">
            <ol class="space-y-2">
                @foreach (var item in Model.Outline)
                {
                    var indentClass = item.Level > 2 ? "pl-4" : string.Empty;
                    <li class="@indentClass">
                        <a href="#@item.Id"
                           data-doc-outline-link="true"
                           class="text-sm text-slate-300 hover:text-cyan-400 transition-colors">
                            @item.Title
                        </a>
                    </li>
                }
            </ol>
        </nav>
    </section>
}

<div class="docs-content">
    @* Safe: Content is sanitized by DocAggregator before caching. *@
    @Html.Raw(document.Content)
</div>

@if (Model.HasWayfinding)
{
    <section id="docs-page-wayfinding" class="mt-10 space-y-6 border-t border-slate-800 pt-8">
        @if (Model.PreviousPage is not null || Model.NextPage is not null)
        {
            <div class="space-y-3">
                <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Continue the proof path</div>
                <div class="grid gap-3 md:grid-cols-2">
                    @if (Model.PreviousPage is not null)
                    {
                        <a href="@Model.PreviousPage.Href"
                           data-doc-wayfinding="previous"
                           data-turbo-frame="doc-content"
                           data-turbo-action="advance"
                           class="block rounded-2xl border border-slate-800 bg-slate-900/60 px-4 py-4 transition-colors hover:border-cyan-500/40 hover:bg-slate-900">
                            <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Previous</div>
                            <div class="mt-2 text-base font-semibold text-white">@Model.PreviousPage.Title</div>
                            @if (Model.PreviousPage.PageTypeBadge is not null)
                            {
                                <span class="docs-page-badge docs-page-badge--@Model.PreviousPage.PageTypeBadge.Variant mt-3 inline-flex">@Model.PreviousPage.PageTypeBadge.Label</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.PreviousPage.Summary))
                            {
                                <p class="mt-3 text-sm text-slate-400">@Model.PreviousPage.Summary</p>
                            }
                        </a>
                    }
                    @if (Model.NextPage is not null)
                    {
                        <a href="@Model.NextPage.Href"
                           data-doc-wayfinding="next"
                           data-turbo-frame="doc-content"
                           data-turbo-action="advance"
                           class="block rounded-2xl border border-slate-800 bg-slate-900/60 px-4 py-4 transition-colors hover:border-cyan-500/40 hover:bg-slate-900">
                            <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Next</div>
                            <div class="mt-2 text-base font-semibold text-white">@Model.NextPage.Title</div>
                            @if (Model.NextPage.PageTypeBadge is not null)
                            {
                                <span class="docs-page-badge docs-page-badge--@Model.NextPage.PageTypeBadge.Variant mt-3 inline-flex">@Model.NextPage.PageTypeBadge.Label</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.NextPage.Summary))
                            {
                                <p class="mt-3 text-sm text-slate-400">@Model.NextPage.Summary</p>
                            }
                        </a>
                    }
                </div>
            </div>
        }

        @if (Model.RelatedPages.Count > 0)
        {
            <div class="space-y-3">
                <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Related pages</div>
                <div class="grid gap-3 md:grid-cols-2">
                    @foreach (var relatedPage in Model.RelatedPages)
                    {
                        <a href="@relatedPage.Href"
                           data-doc-related-link="true"
                           data-turbo-frame="doc-content"
                           data-turbo-action="advance"
                           class="block rounded-2xl border border-slate-800 bg-slate-900/40 px-4 py-4 transition-colors hover:border-cyan-500/40 hover:bg-slate-900">
                            <div class="text-base font-semibold text-white">@relatedPage.Title</div>
                            @if (relatedPage.PageTypeBadge is not null)
                            {
                                <span class="docs-page-badge docs-page-badge--@relatedPage.PageTypeBadge.Variant mt-3 inline-flex">@relatedPage.PageTypeBadge.Label</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(relatedPage.Summary))
                            {
                                <p class="mt-3 text-sm text-slate-400">@relatedPage.Summary</p>
                            }
                        </a>
                    }
                </div>
            </div>
        }
    </section>
}
