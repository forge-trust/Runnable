@model ForgeTrust.Runnable.Web.RazorDocs.Models.DocLandingViewModel
@{
    ViewData["Title"] = "Documentation Index";
}

<div class="mx-auto max-w-5xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <div class="mb-10 max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-cyan-300">Documentation</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">@Model.Heading</h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">@Model.Description</p>
    </div>

    <section class="rounded-3xl border border-cyan-500/30 bg-slate-900/80 p-6 shadow-[0_0_0_1px_rgba(34,211,238,0.06)] sm:p-8">
        <div class="flex flex-col gap-4 border-b border-slate-800 pb-5 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-cyan-300">Start Here</p>
                <h2 class="mt-2 text-2xl font-semibold tracking-tight text-white">Follow the proof path first.</h2>
                <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">
                    Understand what the system is for, see it working, then choose the next implementation route with context.
                </p>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.StartHereHref))
            {
                <a href="@Model.StartHereHref"
                   class="inline-flex items-center gap-2 self-start rounded-full border border-cyan-500/40 bg-cyan-500/10 px-4 py-2 text-sm font-semibold text-cyan-200 transition-colors hover:border-cyan-400 hover:bg-cyan-500/15">
                    Open Start Here
                    <span aria-hidden="true">-&gt;</span>
                </a>
            }
        </div>

        @if (Model.FeaturedPageGroups.Count > 0)
        {
            <div class="mt-6 space-y-8">
                @foreach (var featuredGroup in Model.FeaturedPageGroups)
                {
                    <section class="border-t border-slate-800 pt-5 first:border-t-0 first:pt-0">
                        <div class="max-w-3xl">
                            <h3 class="text-base font-semibold text-white">@featuredGroup.Label</h3>
                            @if (!string.IsNullOrWhiteSpace(featuredGroup.Summary))
                            {
                                <p class="mt-2 text-sm leading-6 text-slate-300">@featuredGroup.Summary</p>
                            }
                        </div>
                        <ul class="mt-4 space-y-3">
                            @foreach (var featuredPage in featuredGroup.Pages)
                            {
                                <li>
                                    <a href="@featuredPage.Href"
                                       data-turbo-frame="doc-content"
                                       data-turbo-action="advance"
                                       class="group block rounded-2xl border border-slate-800 bg-slate-950/50 px-5 py-4 transition-colors hover:border-cyan-500/40 hover:bg-slate-950">
                                        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                                            <div class="min-w-0 flex-1">
                                                <div class="flex flex-wrap items-center gap-3">
                                                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-300">@featuredPage.Question</p>
                                                    @if (featuredPage.PageTypeBadge is not null)
                                                    {
                                                        <span class="docs-page-badge docs-page-badge--@featuredPage.PageTypeBadge.Variant">
                                                            @featuredPage.PageTypeBadge.Label
                                                        </span>
                                                    }
                                                </div>
                                                <h4 class="mt-3 text-lg font-semibold text-white transition-colors group-hover:text-cyan-100">@featuredPage.Title</h4>
                                                @if (!string.IsNullOrWhiteSpace(featuredPage.SupportingText))
                                                {
                                                    <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-300">@featuredPage.SupportingText</p>
                                                }
                                            </div>
                                            <span class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-200 transition-colors group-hover:text-cyan-100">
                                                Open page
                                                <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">-&gt;</span>
                                            </span>
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    </section>
                }
            </div>
        }
    </section>

    @if (Model.SecondarySections.Count > 0)
    {
        <div class="mt-10 space-y-6">
            @foreach (var secondarySection in Model.SecondarySections)
            {
                <section class="border-b border-slate-900/80 pb-6 last:border-b-0 last:pb-0">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                        <div class="min-w-0 flex-1">
                            <a href="@secondarySection.Href"
                               class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400 transition-colors hover:text-cyan-300">
                                @secondarySection.Label
                            </a>
                            <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-300">@secondarySection.Purpose</p>
                        </div>
                    </div>

                    @if (secondarySection.KeyRoutes.Count > 0)
                    {
                        <ul class="mt-4 space-y-3">
                            @foreach (var route in secondarySection.KeyRoutes)
                            {
                                <li>
                                    <a href="@route.Href"
                                       data-turbo-frame="doc-content"
                                       data-turbo-action="advance"
                                       class="group flex flex-col gap-2 rounded-2xl border border-slate-900 bg-slate-950/30 px-4 py-3 transition-colors hover:border-cyan-500/30 hover:bg-slate-950/60 sm:flex-row sm:items-start sm:justify-between">
                                        <div class="min-w-0 flex-1">
                                            @if (!string.IsNullOrWhiteSpace(route.Eyebrow))
                                            {
                                                <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500">@route.Eyebrow</p>
                                            }
                                            <div class="mt-1 flex flex-wrap items-center gap-2">
                                                <span class="text-base font-semibold text-white transition-colors group-hover:text-cyan-100">@route.Title</span>
                                                @if (route.PageTypeBadge is not null)
                                                {
                                                    <span class="docs-page-badge docs-page-badge--@route.PageTypeBadge.Variant">
                                                        @route.PageTypeBadge.Label
                                                    </span>
                                                }
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(route.Summary))
                                            {
                                                <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-400">@route.Summary</p>
                                            }
                                        </div>
                                        <span class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-200 transition-colors group-hover:text-cyan-100">
                                            Open
                                            <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">-&gt;</span>
                                        </span>
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                </section>
            }
        </div>
    }
</div>
