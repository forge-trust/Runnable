@model ForgeTrust.Runnable.Web.RazorDocs.Models.DocSectionPageViewModel
@{
    ViewData["Title"] = Model.Heading;
}

<div class="mx-auto max-w-5xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Section</p>
        <h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">@Model.Heading</h1>
        <p class="mt-4 text-base leading-7 text-slate-300">@Model.Description</p>
        @if (!string.IsNullOrWhiteSpace(Model.AvailabilityMessage))
        {
            <p class="mt-3 text-sm leading-6 text-slate-400">@Model.AvailabilityMessage</p>
        }
    </div>

    <div class="mt-6 flex flex-wrap gap-3">
        @if (!string.IsNullOrWhiteSpace(Model.StartHereHref))
        {
            <a href="@Model.StartHereHref"
               class="inline-flex items-center gap-2 rounded-full border border-cyan-500/40 bg-cyan-500/10 px-4 py-2 text-sm font-semibold text-cyan-200 transition-colors hover:border-cyan-400 hover:bg-cyan-500/15">
                Start Here
            </a>
        }
        <a href="@Model.DocsHomeHref"
           class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/70 px-4 py-2 text-sm font-semibold text-slate-200 transition-colors hover:border-slate-600 hover:bg-slate-900">
            Docs home
        </a>
    </div>

    @if (!Model.IsUnavailable && Model.IsSparse && Model.KeyRoutes.Count > 0)
    {
        <section class="mt-8 rounded-2xl border border-slate-800 bg-slate-950/40 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">This section is still growing</p>
            <p class="mt-3 text-sm leading-6 text-slate-300">
                The section is intentionally lean right now. Start with the strongest visible route below and come back as more material lands.
            </p>
            <ul class="mt-4 space-y-3">
                @foreach (var route in Model.KeyRoutes)
                {
                    <li>
                        <a href="@route.Href"
                           data-turbo-frame="doc-content"
                           data-turbo-action="advance"
                           class="group flex flex-col gap-2 rounded-xl border border-slate-900 bg-slate-950/60 px-4 py-3 transition-colors hover:border-cyan-500/30 hover:bg-slate-950">
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="text-base font-semibold text-white transition-colors group-hover:text-cyan-100">@route.Title</span>
                                @if (route.PageTypeBadge is not null)
                                {
                                    <span class="docs-page-badge docs-page-badge--@route.PageTypeBadge.Variant">@route.PageTypeBadge.Label</span>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(route.Summary))
                            {
                                <p class="text-sm leading-6 text-slate-400">@route.Summary</p>
                            }
                        </a>
                    </li>
                }
            </ul>
        </section>
    }

    @if (!Model.IsUnavailable && Model.Groups.Count > 0)
    {
        <section class="mt-10">
            <div class="mb-4 flex items-end justify-between gap-4">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">In this section</p>
                    <h2 class="mt-2 text-xl font-semibold text-white">Browse the public pages here.</h2>
                </div>
            </div>

            <div class="space-y-6">
                @foreach (var group in Model.Groups)
                {
                    <section>
                        @if (!string.IsNullOrWhiteSpace(group.Title))
                        {
                            <h3 class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">@group.Title</h3>
                        }

                        <ul class="space-y-3">
                            @foreach (var link in group.Links)
                            {
                                <li>
                                    <a href="@link.Href"
                                       data-turbo-frame="doc-content"
                                       data-turbo-action="advance"
                                       class="group block rounded-2xl border border-slate-900 bg-slate-950/30 px-4 py-3 transition-colors hover:border-cyan-500/30 hover:bg-slate-950/60">
                                        <div class="flex flex-wrap items-center gap-2">
                                            <span class="text-base font-semibold text-white transition-colors group-hover:text-cyan-100">@link.Title</span>
                                            @if (link.PageTypeBadge is not null)
                                            {
                                                <span class="docs-page-badge docs-page-badge--@link.PageTypeBadge.Variant">@link.PageTypeBadge.Label</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(link.Summary))
                                        {
                                            <p class="mt-2 text-sm leading-6 text-slate-400">@link.Summary</p>
                                        }
                                    </a>

                                    @if (link.Children.Count > 0)
                                    {
                                        <ul class="ml-4 mt-2 space-y-1 border-l border-slate-800">
                                            @foreach (var child in link.Children)
                                            {
                                                <li>
                                                    <a href="@child.Href"
                                                       data-doc-anchor-link="true"
                                                       data-turbo-frame="doc-content"
                                                       data-turbo-action="advance"
                                                       class="block px-4 py-1 text-xs text-slate-500 transition-colors hover:text-cyan-300">
                                                        @child.Title
                                                    </a>
                                                </li>
                                            }
                                        </ul>
                                    }
                                </li>
                            }
                        </ul>
                    </section>
                }
            </div>
        </section>
    }
</div>
