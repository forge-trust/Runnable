@model ForgeTrust.Runnable.Web.RazorDocs.Models.DocSidebarViewModel

@foreach (var sidebarSection in Model.Sections)
{
    <details class="group border-b border-slate-900/80 py-2 last:border-b-0" @(sidebarSection.IsExpanded ? "open" : null)>
        <summary class="list-none cursor-pointer">
            <div class="flex items-center justify-between gap-3 rounded-xl px-2 py-2 transition-colors hover:bg-slate-900/70">
                <a href="@sidebarSection.Href"
                   class="text-xs font-semibold uppercase tracking-[0.18em] @(sidebarSection.IsActive ? "text-cyan-300" : "text-slate-400 hover:text-cyan-300")"
                   @(sidebarSection.IsActive ? "aria-current=\"location\"" : null)>
                    @sidebarSection.Label
                </a>
                <span class="text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-600 transition-transform group-open:rotate-90" aria-hidden="true">›</span>
            </div>
        </summary>

        <div class="mt-1 space-y-3 px-2 pb-2">
            @foreach (var sectionGroup in sidebarSection.Groups)
            {
                <div class="space-y-1">
                    @if (!string.IsNullOrWhiteSpace(sectionGroup.Title))
                    {
                        <div class="px-2 pb-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-600">@sectionGroup.Title</div>
                    }

                    <ul class="space-y-1">
                        @foreach (var link in sectionGroup.Links)
                        {
                            <li>
                                <a href="@link.Href"
                                   data-turbo-frame="doc-content"
                                   data-turbo-action="advance"
                                   class="block rounded-lg px-2 py-1.5 text-sm font-medium transition-colors @(link.IsCurrent ? "bg-slate-900 text-cyan-200" : "text-slate-400 hover:bg-slate-900 hover:text-cyan-300")"
                                   @(link.IsCurrent ? "aria-current=\"page\"" : null)>
                                    @link.Title
                                </a>

                                @if (link.Children.Count > 0)
                                {
                                    <ul class="ml-4 mt-1 space-y-0.5 border-l border-slate-800">
                                        @foreach (var child in link.Children)
                                        {
                                            <li>
                                                <a href="@child.Href"
                                                   data-doc-anchor-link="true"
                                                   data-turbo-frame="doc-content"
                                                   data-turbo-action="advance"
                                                   class="block px-4 py-1 text-xs transition-colors @(child.IsCurrent ? "text-cyan-300" : "text-slate-500 hover:text-cyan-300")"
                                                   @(child.IsCurrent ? "aria-current=\"page\"" : null)>
                                                    @child.Title
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                }
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </details>
}
