@model ForgeTrust.Runnable.Web.RazorDocs.Models.DocDetailsViewModel

<header class="@(Model.IsCSharpApiDoc ? "mb-5" : "mb-8")">
    @if (!string.IsNullOrWhiteSpace(Model.PublicSectionLabel) && !string.IsNullOrWhiteSpace(Model.PublicSectionHref))
    {
        <div class="mb-4 md:hidden">
            <a href="@Model.PublicSectionHref"
               class="inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/80 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-slate-200 transition-colors hover:border-cyan-500/40 hover:text-cyan-200">
                <span class="text-slate-500">Section</span>
                <span>@Model.PublicSectionLabel</span>
            </a>
        </div>
    }

    @if (Model.Breadcrumbs.Count > 0)
    {
        <nav aria-label="Breadcrumb" class="mb-3 flex flex-wrap items-center gap-1 text-xs font-mono text-slate-500">
            @for (var i = 0; i < Model.Breadcrumbs.Count; i++)
            {
                var crumb = Model.Breadcrumbs[i];
                var isLast = i == Model.Breadcrumbs.Count - 1;

                if (isLast || string.IsNullOrWhiteSpace(crumb.Href))
                {
                    <span class="inline-flex max-w-full overflow-x-auto whitespace-nowrap rounded border border-slate-700 bg-slate-800 px-2 py-0.5">@crumb.Label</span>
                }
                else
                {
                    <a href="@crumb.Href"
                       data-turbo-frame="doc-content"
                       data-turbo-action="advance"
                       class="px-1 text-slate-400 transition-colors hover:text-cyan-400">
                        @crumb.Label
                    </a>
                }

                if (!isLast)
                {
                    <span class="text-slate-600">/</span>
                }
            }
        </nav>
    }

    @if (Model.PageTypeBadge is not null || Model.Component is not null || Model.Audience is not null)
    {
        <div class="docs-page-meta">
            @if (Model.PageTypeBadge is not null)
            {
                <span class="docs-page-badge docs-page-badge--@Model.PageTypeBadge.Variant">@Model.PageTypeBadge.Label</span>
            }
            @if (Model.Component is not null)
            {
                <span class="docs-metadata-chip">Component: @Model.Component</span>
            }
            @if (Model.Audience is not null)
            {
                <span class="docs-metadata-chip">Audience: @Model.Audience</span>
            }
        </div>
    }

    @if (!Model.IsCSharpApiDoc)
    {
        <h1 class="text-3xl font-bold tracking-tight text-white">@Model.Title</h1>
        @if (Model.ShowSummary && !string.IsNullOrWhiteSpace(Model.Summary))
        {
            <p class="mt-3 max-w-3xl text-base text-slate-400">@Model.Summary</p>
        }
    }
</header>

@if (Model.IsSectionLanding)
{
    <section class="mb-10 rounded-2xl border border-slate-800 bg-slate-950/35 p-5 sm:p-6">
        <div class="flex flex-col gap-3 border-b border-slate-800 pb-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-300">Section landing</p>
                <h2 class="mt-2 text-xl font-semibold text-white">Use this section as the entry point.</h2>
                @if (!string.IsNullOrWhiteSpace(Model.PublicSectionPurpose))
                {
                    <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-300">@Model.PublicSectionPurpose</p>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.PublicSectionHref))
            {
                <a href="@Model.PublicSectionHref"
                   class="inline-flex items-center gap-2 self-start rounded-full border border-slate-700 bg-slate-900/70 px-4 py-2 text-sm font-semibold text-slate-200 transition-colors hover:border-cyan-500/40 hover:text-cyan-200">
                    Section route
                </a>
            }
        </div>

        @if (Model.FeaturedPages.Count > 0)
        {
            <div class="mt-5">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Next steps</p>
                <ul class="mt-3 space-y-3">
                    @foreach (var featuredPage in Model.FeaturedPages)
                    {
                        <li>
                            <a href="@featuredPage.Href"
                               data-turbo-frame="doc-content"
                               data-turbo-action="advance"
                               class="group block rounded-xl border border-slate-900 bg-slate-950/60 px-4 py-3 transition-colors hover:border-cyan-500/30 hover:bg-slate-950">
                                <div class="flex flex-wrap items-center gap-2">
                                    @if (!string.IsNullOrWhiteSpace(featuredPage.Question))
                                    {
                                        <span class="text-[10px] font-semibold uppercase tracking-[0.18em] text-cyan-300">@featuredPage.Question</span>
                                    }
                                    @if (featuredPage.PageTypeBadge is not null)
                                    {
                                        <span class="docs-page-badge docs-page-badge--@featuredPage.PageTypeBadge.Variant">@featuredPage.PageTypeBadge.Label</span>
                                    }
                                </div>
                                <h3 class="mt-2 text-base font-semibold text-white transition-colors group-hover:text-cyan-100">@featuredPage.Title</h3>
                                @if (!string.IsNullOrWhiteSpace(featuredPage.SupportingText))
                                {
                                    <p class="mt-2 text-sm leading-6 text-slate-400">@featuredPage.SupportingText</p>
                                }
                            </a>
                        </li>
                    }
                </ul>
            </div>
        }

        @if (Model.SectionGroups.Count > 0)
        {
            <div class="mt-6">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">In this section</p>
                <div class="mt-3 space-y-5">
                    @foreach (var sectionGroup in Model.SectionGroups)
                    {
                        <section>
                            @if (!string.IsNullOrWhiteSpace(sectionGroup.Title))
                            {
                                <h3 class="mb-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500">@sectionGroup.Title</h3>
                            }
                            <ul class="space-y-3">
                                @foreach (var link in sectionGroup.Links)
                                {
                                    <li>
                                        <a href="@link.Href"
                                           data-turbo-frame="doc-content"
                                           data-turbo-action="advance"
                                           class="group block rounded-xl border border-slate-900 bg-slate-950/50 px-4 py-3 transition-colors hover:border-cyan-500/30 hover:bg-slate-950">
                                            <div class="flex flex-wrap items-center gap-2">
                                                <span class="text-sm font-semibold text-white transition-colors group-hover:text-cyan-100">@link.Title</span>
                                                @if (link.PageTypeBadge is not null)
                                                {
                                                    <span class="docs-page-badge docs-page-badge--@link.PageTypeBadge.Variant">@link.PageTypeBadge.Label</span>
                                                }
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(link.Summary))
                                            {
                                                <p class="mt-2 text-sm leading-6 text-slate-400">@link.Summary</p>
                                            }
                                        </a>

                                        @if (link.Children.Count > 0)
                                        {
                                            <ul class="ml-4 mt-2 space-y-1 border-l border-slate-800">
                                                @foreach (var child in link.Children)
                                                {
                                                    <li>
                                                        <a href="@child.Href"
                                                           data-doc-anchor-link="true"
                                                           data-turbo-frame="doc-content"
                                                           data-turbo-action="advance"
                                                           class="block px-4 py-1 text-xs text-slate-500 transition-colors hover:text-cyan-300">
                                                            @child.Title
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </li>
                                }
                            </ul>
                        </section>
                    }
                </div>
            </div>
        }
    </section>
}

<div class="docs-content">
    @* Safe: Content is sanitized by DocAggregator before caching. *@
    @Html.Raw(Model.Document.Content)
</div>
