@using ForgeTrust.Runnable.Web
@model ForgeTrust.Runnable.Web.NotFoundPageModel
@{
    Layout = null;
    var missingPath = string.IsNullOrWhiteSpace(Model.OriginalPath)
        ? "the requested page"
        : Model.OriginalPath;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Page Not Found</title>
    <style>
        :root {
            color-scheme: light;
            font-family: "Segoe UI", sans-serif;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%);
            color: #0f172a;
        }

        main {
            width: min(36rem, calc(100% - 2rem));
            padding: 2rem;
            border-radius: 1.5rem;
            background: rgba(255, 255, 255, 0.92);
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
        }

        h1 {
            margin-top: 0;
            margin-bottom: 0.75rem;
            font-size: clamp(2rem, 5vw, 3rem);
        }

        p {
            margin: 0 0 1rem;
            line-height: 1.6;
        }

        code {
            padding: 0.2rem 0.45rem;
            border-radius: 999px;
            background: #e2e8f0;
            font-size: 0.95rem;
        }
    </style>
</head>
<body>
<main>
    <p>Runnable default 404</p>
    <h1>Page not found</h1>
    <p>We couldn't find <code>@missingPath</code>.</p>
    <p>Add <code>@ConventionalNotFoundPageDefaults.AppViewPath</code> in your app or a shared Razor Class Library to replace this fallback page.</p>
</main>
</body>
</html>
