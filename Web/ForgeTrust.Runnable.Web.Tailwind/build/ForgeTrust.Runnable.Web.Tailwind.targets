<Project>
  <PropertyGroup>
    <TailwindEnabled Condition="'$(TailwindEnabled)' == ''">true</TailwindEnabled>
    <TailwindInputPath Condition="'$(TailwindInputPath)' == ''">wwwroot/css/app.css</TailwindInputPath>
    <TailwindOutputPath Condition="'$(TailwindOutputPath)' == ''">wwwroot/css/site.css</TailwindOutputPath>
  </PropertyGroup>

  <Target Name="RunTailwindBuild" BeforeTargets="BeforeBuild" Condition="'$(TailwindEnabled)' == 'true' AND Exists('$(TailwindInputPath)')">
    <PropertyGroup>
      <!-- Try to find the binary in the package or project relative folder -->
      <_TailwindToolPath>$(MSBuildThisFileDirectory)../runtimes/$(RuntimeIdentifier)/native/tailwindcss</_TailwindToolPath>
      <_TailwindToolPath Condition="!Exists('$(_TailwindToolPath)')">$(MSBuildThisFileDirectory)../tailwindcss</_TailwindToolPath>
      <_TailwindToolPath Condition="$([MSBuild]::IsOSPlatform('Windows'))">$(_TailwindToolPath).exe</_TailwindToolPath>
    </PropertyGroup>

    <Message Importance="High" Text="Tailwind CSS: Running build for $(TailwindInputPath) -> $(TailwindOutputPath)" />
    <Exec Command="&quot;$(_TailwindToolPath)&quot; -i &quot;$(TailwindInputPath)&quot; -o &quot;$(TailwindOutputPath)&quot; --minify" 
          WorkingDirectory="$(MSBuildProjectDirectory)" />
  </Target>
</Project>
